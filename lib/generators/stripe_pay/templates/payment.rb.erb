class Payment < ApplicationRecord
  # Polymorphic association - can be attached to ANY business model
  # Examples: Order (has_one), Subscription (has_many), Booking, Course, etc.
  belongs_to :payable, polymorphic: true, optional: true
<% if @auth -%>
  belongs_to :user, optional: true
  # CLACKY_NOTE: User is optional to support:
  # - Normal case: payment.user == payable.user (most common)
  # - Anonymous: payment.user = nil, uses customer_email from payable instead
<% else -%>
  validates :customer_email, presence: true, format: { with: URI::MailTo::EMAIL_REGEXP }
<% end -%>

  # Core validations
  validates :amount, presence: true, numericality: { greater_than: 0 }
  validates :currency, presence: true
  validates :status, presence: true, inclusion: { in: %w[pending processing paid failed canceled refunded] }

  # Scopes
  scope :pending,    -> { where(status: 'pending') }
  scope :processing, -> { where(status: 'processing') }
  scope :paid,       -> { where(status: 'paid') }
  scope :failed,     -> { where(status: 'failed') }
  scope :canceled,   -> { where(status: 'canceled') }
  scope :refunded,   -> { where(status: 'refunded') }
  scope :recent,     -> { order(created_at: :desc) }

  # Status check methods
  def pending?   = status == 'pending'
  def processing? = status == 'processing'
  def paid?      = status == 'paid'
  def failed?    = status == 'failed'
  def canceled?  = status == 'canceled'
  def refunded?  = status == 'refunded'
  def completed? = paid?

  alias_method :succeeded?, :paid?

  # Status transitions
  def mark_as_processing!
    update!(status: 'processing')
  end

  def mark_as_paid!
    update!(status: 'paid')
  end

  def mark_as_failed!
    update!(status: 'failed')
  end

  def mark_as_canceled!
    update!(status: 'canceled')
  end

  # Get customer email — from direct field or via payable
  def customer_email
<% if @auth -%>
    read_attribute(:customer_email).presence || payable&.customer_email
<% else -%>
    read_attribute(:customer_email)
<% end -%>
  end

  # Formatted amount for display
  def formatted_amount
    "#{currency.upcase} #{'%.2f' % amount}"
  end

  # Description from the payable object
  def description
    payable&.payment_description || "Payment ##{id}"
  end

  # ============================================================
  # Payable Interface Contract
  # ============================================================
  # Any model used as :payable MUST implement:
  #
  #   def customer_name        → String: payer's display name
  #   def customer_email       → String: payer's email address
  #   def payment_description  → String: human-readable description
  #   def process_payment_paid → called when payment is confirmed
  #
  # Example (Order model):
  #
  #   def customer_name        = user.name
  #   def customer_email       = user.email
  #   def payment_description  = "Order ##{id} — #{items.count} items"
  #   def process_payment_paid
  #     update!(status: 'paid')
  #     user.add_credits(credits_amount)
  #   end
  # ============================================================
end
