require 'rails_helper'

RSpec.describe "Payment Integration", type: :request do
  describe "Payable models interface" do
    it "validates all payable models implement required methods" do
      Rails.application.eager_load!
      payable_models = ApplicationRecord.descendants.select do |model|
        assoc = model.reflect_on_association(:payment) || model.reflect_on_association(:payments)
        assoc&.options&.dig(:as) == :payable
      end

      payable_models.each do |model|
        factory = model.model_name.singular.to_sym
        instance = build(factory)

        expect(instance.customer_name).to be_a(String).and be_present,
          "#{model} must implement #customer_name returning a non-blank String"
        expect(instance.customer_email).to match(URI::MailTo::EMAIL_REGEXP),
          "#{model} must implement #customer_email returning a valid email"
        expect(instance.payment_description).to be_a(String).and be_present,
          "#{model} must implement #payment_description returning a non-blank String"
        expect(instance).to respond_to(:process_payment_paid),
          "#{model} must implement #process_payment_paid"
      end
    end
  end

  describe "Payment views" do
    it "requires pay view to exist" do
      expect(
        File.exist?("app/views/payments/pay.html.erb")
      ).to be(true), "Missing app/views/payments/pay.html.erb — required for payment confirmation page"
    end

    it "requires success view to exist" do
      expect(
        File.exist?("app/views/payments/success.html.erb")
      ).to be(true), "Missing app/views/payments/success.html.erb — required for post-payment page"
    end
  end

  describe "FakePayService" do
    let(:payable) do
      double("Payable",
        customer_name: "Test User",
        customer_email: "test@example.com",
        payment_description: "Test Payment",
        process_payment_paid: true
      )
    end

    let(:payment) do
      Payment.new(
        amount: 99.0,
        currency: "usd",
        status: "pending",
        payable: payable
<% if @auth -%>
        # user: nil  # optional in --auth mode
<% end -%>
      )
    end

    it "transitions payment to paid and calls process_payment_paid" do
      allow(payment).to receive(:mark_as_processing!)
      allow(payment).to receive(:mark_as_paid!)
      allow(payment).to receive(:pending?).and_return(true)
      allow(payment).to receive(:failed?).and_return(false)

      result = FakePayService.new(payment).call

      expect(result[:success]).to be(true)
      expect(payable).to have_received(:process_payment_paid)
    end
  end
end
