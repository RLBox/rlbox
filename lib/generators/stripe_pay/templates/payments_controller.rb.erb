class PaymentsController < ApplicationController
<% if @auth -%>
  before_action :authenticate_user!
<% end -%>
  before_action :set_payment

  # GET /payments/:id/pay
  # Show payment confirmation page
  def pay
    # GET: render confirmation page
    # POST: handled by Rails routing to the same action name
    # For POST, use a separate action or check request method
    if request.post?
      process_pay
    end
    # GET falls through to render pay.html.erb
  end

  # GET /payments/:id/success
  def success
  end

  # GET /payments/:id/failure
  def failure
  end

  private

  def process_pay
    result = FakePayService.new(@payment).call
    if result[:success]
      redirect_to success_payment_path(@payment)
    else
      flash[:alert] = result[:error]
      redirect_to failure_payment_path(@payment)
    end
  end

  def set_payment
    @payment = Payment.find(params[:id])
<% if @auth -%>
    # Ensure user can only view their own payments
    unless @payment.user == current_user
      redirect_to root_path, alert: "Access denied"
      return
    end
<% end -%>
  end
end
