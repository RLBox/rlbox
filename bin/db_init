#!/usr/bin/env ruby
# frozen_string_literal: true
#
# bin/db_init — 数据库一键初始化（从零搭建 / 重建）
#
# 适用场景：
#   - 新克隆项目，第一次搭建本地环境
#   - 换一台开发机
#   - 想把数据库推倒重建（删库后从头来）
#
# 执行步骤：
#   1. 读 database.yml 拿到 dev / test 数据库名 / 用户名 / 密码
#   2. 以 superuser 身份连 postgres 库，创建 app_user（NOSUPERUSER，RLS 必需）
#   3. 以 superuser 创建 dev / test 数据库，并把 owner 设为 app_user
#      → 这样 app_user 建的表天然归自己所有，后续 migration 可以 ALTER TABLE
#   4. 授予 app_user 必要权限 + 注册 app.data_version GUC 参数（RLS 依赖）
#   5. 运行 db:migrate（会启用 RLS policy）
#   6. 加载 baseline 数据包（rake validator:reset_baseline）
#   7. 自检：确认 app_user 非 superuser + RLS policy 数量 ≥ 4
#
# 前置条件：
#   - PostgreSQL 运行中
#   - 能以 superuser（默认 `postgres`）连接本机 PG
#     覆盖方法: PGSUPERUSER=your_super bin/db_init
#
# 默认行为（2026-05-04 起）：
#   - 💣 DROP 后重建（开发库数据一律清空，baseline 由 data pack 重建）
#   - 理由：开发库本来就是一次性的；"增量幂等"模式容易踩 migration 撞号 / 残留旧表等坑
#
# 变更历史：
#   - 老版本默认"幂等增量"，DROP=1 显式触发重建
#   - 现在默认 DROP；如需保留数据: KEEP=1 bin/db_init（走老的增量路径）

require 'fileutils'
require 'yaml'
require 'erb'

APP_ROOT = File.expand_path('..', __dir__)

# Load .env if present — keeps db_init consistent with bin/dev / puma.
# Without this, WORKTREE_DEV_DB / WORKTREE_TEST_DB in .env are invisible here,
# and db_init would initialize the wrong database (fallback to <app>_development)
# while the server reads the worktree-specific DB → NoDatabaseError 500.
env_file = File.join(APP_ROOT, '.env')
if File.exist?(env_file)
  File.readlines(env_file).each do |line|
    line = line.strip
    next if line.empty? || line.start_with?('#')
    key, value = line.split('=', 2)
    ENV[key.strip] ||= value.strip if key && value
  end
end

def system!(*args)
  system(*args) || abort("\n❌ Command #{args.inspect} failed")
end

def psql(db, sql, superuser:)
  IO.popen(%W[psql -h #{ENV.fetch('PGHOST', 'localhost')} -U #{superuser} -d #{db} -v ON_ERROR_STOP=1 -q], 'w') do |p|
    p.write(sql)
  end
  $?.success? || abort("❌ psql 失败: db=#{db}")
end

def appname
  path = File.join(APP_ROOT, 'config', 'appname.txt')
  File.exist?(path) ? File.read(path).strip : 'Rails App'
end

FileUtils.chdir(APP_ROOT) do
  puts
  puts '=' * 60
  puts "🚀 #{appname} 数据库初始化"
  puts '=' * 60

  # === Step 0: 解析 database.yml，拿到实际的库名 / 用户名 / 密码 ===
  db_config = YAML.safe_load(ERB.new(File.read('config/database.yml')).result, aliases: true)
  dev_db  = ENV['WORKTREE_DEV_DB']  || db_config.dig('development', 'database') or abort('❌ database.yml 缺 development.database')
  test_db = ENV['WORKTREE_TEST_DB'] || db_config.dig('test', 'database')         or abort('❌ database.yml 缺 test.database')
  app_user = db_config.dig('development', 'username')  or abort('❌ database.yml 缺 development.username')
  app_pass = db_config.dig('development', 'password') || ENV['DB_PASSWORD'] || 'postgres'

  superuser = ENV.fetch('PGSUPERUSER', 'postgres')
  # 默认 DROP；KEEP=1 保留数据走老的增量路径；DROP=1 向后兼容（等价默认）
  drop_first = ENV['KEEP'] != '1'

  puts
  puts "  超级用户:    #{superuser}"
  puts "  app 用户:    #{app_user}"
  puts "  开发库:      #{dev_db}"
  puts "  测试库:      #{test_db}"
  puts "  模式:        #{drop_first ? '💣 DROP 后重建' : '幂等增量'}"
  puts

  # === Step 1: 创建 app_user 角色（幂等） ===
  puts '📊 [1/5] 创建 / 校准 app_user 角色...'
  psql('postgres', <<~SQL, superuser: superuser)
    DO $$
    BEGIN
      IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname = '#{app_user}') THEN
        -- NOSUPERUSER 是 RLS 生效的关键（superuser 会 bypass RLS）
        -- CREATEDB 是给 db:test:prepare 用的（DROP+CREATE test 库）
        CREATE ROLE #{app_user} WITH LOGIN NOSUPERUSER CREATEDB INHERIT NOCREATEROLE NOREPLICATION PASSWORD '#{app_pass}';
        RAISE NOTICE 'Created role %', '#{app_user}';
      END IF;
    END $$;
    ALTER ROLE #{app_user} WITH PASSWORD '#{app_pass}' CREATEDB;
  SQL
  puts "  ✓ #{app_user} 就绪（NOSUPERUSER + CREATEDB，RLS 对其生效）"

  # === Step 2: 创建数据库（owner = app_user） ===
  puts "\n📊 [2/5] 创建数据库..."
  [dev_db, test_db].each do |db|
    if drop_first
      system("dropdb -h #{ENV.fetch('PGHOST', 'localhost')} -U #{superuser} --if-exists #{db}")
    end

    # 用 createdb 比 CREATE DATABASE 更直接；已存在会报错但不致命
    exists = system("psql -h #{ENV.fetch('PGHOST', 'localhost')} -U #{superuser} -d postgres -tAc \"SELECT 1 FROM pg_database WHERE datname='#{db}'\" | grep -q 1")
    if exists
      puts "  ⊙ #{db} 已存在，跳过创建"
    else
      system! "createdb -h #{ENV.fetch('PGHOST', 'localhost')} -U #{superuser} -O #{app_user} -T template0 -E UTF8 #{db}"
      puts "  ✓ 创建 #{db}（owner=#{app_user}）"
    end

    # 授权 + 把 owner 改成 app_user（即使库已存在也要保证 owner 正确，
    # 否则 db:test:prepare 等 rake 任务会因 InsufficientPrivilege 失败）
    psql('postgres', <<~SQL, superuser: superuser)
      ALTER DATABASE #{db} OWNER TO #{app_user};
      -- 注册自定义 GUC 参数 app.data_version，RLS policy 依赖它
      -- 这一步必须 superuser（PG 对自定义参数的硬性限制，owner 权限不够）
      ALTER DATABASE #{db} SET app.data_version = '0';
    SQL
    psql(db, <<~SQL, superuser: superuser)
      GRANT ALL PRIVILEGES ON DATABASE #{db} TO #{app_user};
      ALTER SCHEMA public OWNER TO #{app_user};
      GRANT USAGE, CREATE ON SCHEMA public TO #{app_user};
      ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON TABLES TO #{app_user};
      ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON SEQUENCES TO #{app_user};
    SQL
  end

  # === Step 3: 运行迁移（会自动 ENABLE + FORCE RLS） ===
  puts "\n📊 [3/5] 运行 db:migrate..."
  system! 'bin/rails db:migrate'
  # test 库也同步 schema
  system! 'bin/rails db:test:prepare'

  # === Step 4: 加载 baseline 数据 ===
  puts "\n📊 [4/5] 加载 baseline 数据..."
  system! 'bin/rails validator:reset_baseline'

  # === Step 5: 自检 ===
  puts "\n📊 [5/5] 自检 RLS 是否真正生效..."
  check_script = <<~'RUBY'
    conn = ActiveRecord::Base.connection
    user = conn.execute("SELECT current_user").first["current_user"]
    is_super = conn.execute("SELECT usesuper FROM pg_user WHERE usename = current_user").first["usesuper"]
    policies = conn.execute("SELECT COUNT(*)::int AS c FROM pg_policies WHERE schemaname = 'public'").first["c"]
    biz_tables = conn.execute(<<~SQL).first["c"]
      SELECT COUNT(*)::int AS c FROM information_schema.columns
      WHERE table_schema = 'public' AND column_name = 'data_version'
    SQL
    puts "  连接用户:        #{user}"
    puts "  是否 superuser:  #{is_super}"
    puts "  data_version 表: #{biz_tables}"
    puts "  RLS policy 数量: #{policies}"
    abort "❌ 仍是 superuser，RLS 会被绕过！检查 config/database.yml" if is_super
    if biz_tables.positive? && policies.zero?
      warn "  ⚠ 业务表已存在但 RLS policy = 0。运行 `rails g rls_policy <table>` 为每张业务表生成 4-op policy（依赖 ADR-014）。"
    elsif biz_tables.positive? && policies < biz_tables * 4
      warn "  ⚠ RLS policy 数量偏少：#{policies} < #{biz_tables * 4}（业务表 #{biz_tables} 张 × 4-op）。部分业务表可能缺 policy。"
    else
      puts "  ✓ RLS 配置就绪"
    end
  RUBY
  IO.popen(['bin/rails', 'runner', '-'], 'w') { |io| io.write(check_script) }
  abort('❌ 自检失败') unless $?.success?

  puts
  puts '=' * 60
  puts '✅ 初始化完成'
  puts '=' * 60
  puts
  puts '后续命令：'
  puts '  启动应用: bin/dev'
  puts '  运行测试: bundle exec rake test 或 bundle exec rspec'
  puts '  重新加载 baseline: bin/rails validator:reset_baseline'
  puts
end
