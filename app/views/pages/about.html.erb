<section class="py-20 px-6 bg-surface">
  <div class="container-md mx-auto">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold gradient-text mb-6">About RL BOX</h1>
      <p class="text-xl text-secondary max-w-2xl mx-auto">
        We're building the future of organization and collaboration, one box at a time.
      </p>
    </div>

    <!-- Content Card -->
    <div class="card-elevated rounded-2xl p-12 max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl font-bold text-primary mb-6">Our Mission</h2>
      <p class="text-lg text-secondary mb-6">
        At RL BOX, we believe that organization should be effortless and collaboration should be seamless. 
        Our mission is to empower individuals and teams to achieve more by providing intuitive, powerful 
        tools that adapt to your workflow.
      </p>

      <h2 class="text-3xl font-bold text-primary mb-6 mt-12">What We Offer</h2>
      <div class="space-y-4">
        <div class="flex items-start space-x-3">
          <%= lucide_icon "check-circle", class: "w-6 h-6 text-success flex-shrink-0 mt-1" %>
          <div>
            <h3 class="font-bold text-primary mb-2">Smart Organization</h3>
            <p class="text-secondary">Intelligent systems that learn from your behavior and adapt to your needs.</p>
          </div>
        </div>

        <div class="flex items-start space-x-3">
          <%= lucide_icon "check-circle", class: "w-6 h-6 text-success flex-shrink-0 mt-1" %>
          <div>
            <h3 class="font-bold text-primary mb-2">Seamless Collaboration</h3>
            <p class="text-secondary">Real-time tools that bring teams together, no matter where they are.</p>
          </div>
        </div>

        <div class="flex items-start space-x-3">
          <%= lucide_icon "check-circle", class: "w-6 h-6 text-success flex-shrink-0 mt-1" %>
          <div>
            <h3 class="font-bold text-primary mb-2">Enterprise-Grade Security</h3>
            <p class="text-secondary">Your data is protected with industry-leading security measures.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <h3 class="text-2xl font-bold text-primary mb-6">Ready to get started?</h3>
      <div class="flex items-center justify-center space-x-4">
        <%= link_to "Start Free Trial", sign_up_path, class: "btn-gradient px-8 py-4 rounded-xl font-semibold text-lg shadow-lg hover:shadow-xl" %>
        <%= link_to "Contact Us", "#", class: "btn-outline-primary px-8 py-4 rounded-xl font-semibold text-lg" %>
      </div>
    </div>
  </div>
</section>
