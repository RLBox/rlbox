#!/usr/bin/env python3
"""
apk/bin/build — 统一的 APK 打包脚本

用法:
  apk/bin/build                # debug 版（默认；用 Android SDK 默认 debug keystore）
  apk/bin/build --release      # release 版（需要 app/build.gradle 配好 signingConfigs.release）
  apk/bin/build --release --install    # 打包并 adb install -r 到当前 emulator
  apk/bin/build --clean --release      # 先 clean 再打

产物:
  - debug:   apk/app/build/outputs/apk/debug/app-debug.apk        → 复制到 apk/<slug>-debug.apk
  - release: apk/app/build/outputs/apk/release/app-release.apk    → 复制到 apk/<slug>-release.apk

slug 取自 applicationId 最后一段（与 bin/setup 的 key_prefix 一致）。

为什么需要这个脚本:
  - 多应用场景下每次 cd 到 apk/ 跑 ./gradlew 太啰嗦
  - debug/release 切换 + 可选自动安装，一条命令搞定
  - 给 CI/本地重打包提供统一入口（未来接 apks/ 目录自动替换也放这里）
"""

import argparse
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
APK_DIR = SCRIPT_DIR.parent
GRADLEW = APK_DIR / "gradlew"
BUILD_GRADLE = APK_DIR / "app" / "build.gradle"


def die(msg: str, code: int = 1) -> None:
    print(f"❌ {msg}", file=sys.stderr)
    sys.exit(code)


def detect_slug() -> str:
    """从 app/build.gradle 读 applicationId，取最后一段作为 slug。

    com.openclacky.goomart → goomart
    com.sengclaw.duvy      → duvy
    """
    if not BUILD_GRADLE.exists():
        die(f"找不到 {BUILD_GRADLE}")

    text = BUILD_GRADLE.read_text()
    # applicationId "com.foo.bar"
    m = re.search(r'applicationId\s+["\']([^"\']+)["\']', text)
    if not m:
        die("app/build.gradle 里找不到 applicationId")
    app_id = m.group(1)
    slug = app_id.rsplit(".", 1)[-1].lower()
    return slug


def run_gradle(variant: str, clean: bool) -> None:
    """调用 ./gradlew assembleDebug / assembleRelease。"""
    if not GRADLEW.exists():
        die(f"找不到 {GRADLEW}，请在有完整 Android 工程的 apk/ 下执行")

    tasks = []
    if clean:
        tasks.append("clean")
    tasks.append(f"assemble{variant.capitalize()}")

    print(f"🔨 gradle {' '.join(tasks)} ...")
    # 用 bash 执行避免 macOS 上 exec 权限的问题
    cmd = ["bash", str(GRADLEW)] + tasks + ["-q"]
    proc = subprocess.run(cmd, cwd=APK_DIR)
    if proc.returncode != 0:
        die(f"gradle {tasks} 失败（exit {proc.returncode}）", proc.returncode)


def locate_artifact(variant: str) -> Path:
    """定位 Gradle 打出来的 APK。"""
    out_dir = APK_DIR / "app" / "build" / "outputs" / "apk" / variant
    candidates = [
        out_dir / f"app-{variant}.apk",
        out_dir / f"app-{variant}-unsigned.apk",
    ]
    for p in candidates:
        if p.exists():
            if p.name.endswith("-unsigned.apk") and variant == "release":
                die(
                    f"产物是 {p.name}（未签名）。\n"
                    "   说明 app/build.gradle 的 signingConfigs.release 没配好。\n"
                    "   生成 keystore 示例：\n"
                    "     keytool -genkey -v -keystore apk/android.keystore \\\n"
                    "       -alias android -keyalg RSA -keysize 2048 -validity 10000 \\\n"
                    "       -storepass <PWD> -keypass <PWD> \\\n"
                    "       -dname 'CN=app, O=org, C=CN'"
                )
            return p
    die(f"在 {out_dir} 下找不到 APK，Gradle 可能构建失败")


def copy_to_repo_root(src: Path, slug: str, variant: str) -> Path:
    """把产物复制到 apk/<slug>-<variant>.apk，方便分发。"""
    dst = APK_DIR / f"{slug}-{variant}.apk"
    shutil.copyfile(src, dst)
    size_mb = dst.stat().st_size / (1024 * 1024)
    print(f"📦 {dst.relative_to(APK_DIR.parent)}  ({size_mb:.1f} MB)")
    return dst


def adb_install(apk_path: Path) -> None:
    """adb install -r 到当前在线设备。"""
    adb = shutil.which("adb")
    if not adb:
        die("PATH 里找不到 adb；请把 Android SDK 的 platform-tools 加到 PATH")

    # 确认有设备
    devices = subprocess.run(
        [adb, "devices"], capture_output=True, text=True, check=True
    ).stdout
    online = [line for line in devices.splitlines()[1:] if line.strip().endswith("device")]
    if not online:
        die("没有在线的 adb 设备（先启动 emulator 或接手机）")

    print(f"📲 adb install -r {apk_path.name} ...")
    proc = subprocess.run([adb, "install", "-r", str(apk_path)])
    if proc.returncode != 0:
        die(f"adb install 失败（exit {proc.returncode}）", proc.returncode)
    print("✅ 安装成功")


def main() -> None:
    parser = argparse.ArgumentParser(
        description="统一的 APK 打包入口",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "--release",
        action="store_true",
        help="打 release 版（默认 debug）",
    )
    parser.add_argument(
        "--clean",
        action="store_true",
        help="打包前先 gradle clean",
    )
    parser.add_argument(
        "--install",
        action="store_true",
        help="打完 adb install -r 到当前 emulator",
    )
    parser.add_argument(
        "--no-copy",
        action="store_true",
        help="不把产物复制到 apk/<slug>-<variant>.apk",
    )
    args = parser.parse_args()

    variant = "release" if args.release else "debug"
    slug = detect_slug()

    print(f"🦞 应用: {slug}  变体: {variant}")
    run_gradle(variant, clean=args.clean)
    artifact = locate_artifact(variant)
    print(f"✅ Gradle 产物: {artifact.relative_to(APK_DIR.parent)}")

    final = artifact
    if not args.no_copy:
        final = copy_to_repo_root(artifact, slug, variant)

    if args.install:
        adb_install(final)


if __name__ == "__main__":
    main()
