#!/usr/bin/env python3
"""
gen_icons — 从 apk/store_icon.png 生成所有 Android 图标资源

用法:
  python3 apk/bin/gen_icons
  # 或者直接执行（需要可执行权限）
  apk/bin/gen_icons

说明:
  - 源文件: apk/store_icon.png（建议 512×512 的正方形 PNG）
  - 替换 store_icon.png 为你自己的 logo，再运行此脚本即可
  - 脚本会覆盖 apk/app/src/main/res/ 下所有对应的图标文件

依赖:
  pip install Pillow
  # 或: apt-get install python3-pil
"""

import os
import sys
from pathlib import Path

try:
    from PIL import Image
except ImportError:
    print("❌ 缺少 Pillow 依赖，请先安装：")
    print("   pip install Pillow")
    print("   或: apt-get install python3-pil")
    sys.exit(1)

# 脚本路径定位 apk/ 根目录
SCRIPT_DIR = Path(__file__).resolve().parent
APK_DIR = SCRIPT_DIR.parent
RES_DIR = APK_DIR / "app" / "src" / "main" / "res"
SOURCE_ICON = APK_DIR / "store_icon.png"

# 图标规格定义
# 格式: (输出目录, 文件名, 宽, 高)
ICON_SPECS = [
    # ic_launcher — 应用图标（正方形裁剪）
    ("mipmap-mdpi",    "ic_launcher.png",  48,   48),
    ("mipmap-hdpi",    "ic_launcher.png",  72,   72),
    ("mipmap-xhdpi",   "ic_launcher.png",  96,   96),
    ("mipmap-xxhdpi",  "ic_launcher.png",  144,  144),
    ("mipmap-xxxhdpi", "ic_launcher.png",  192,  192),

    # ic_maskable — 自适应图标（留有安全区域的版本，稍大）
    ("mipmap-mdpi",    "ic_maskable.png",  82,   82),
    ("mipmap-hdpi",    "ic_maskable.png",  123,  123),
    ("mipmap-xhdpi",   "ic_maskable.png",  164,  164),
    ("mipmap-xxhdpi",  "ic_maskable.png",  246,  246),
    ("mipmap-xxxhdpi", "ic_maskable.png",  328,  328),

    # splash — 启动屏图标（正方形）
    ("drawable-mdpi",    "splash.png",  300,  300),
    ("drawable-hdpi",    "splash.png",  450,  450),
    ("drawable-xhdpi",   "splash.png",  600,  600),
    ("drawable-xxhdpi",  "splash.png",  900,  900),
    ("drawable-xxxhdpi", "splash.png",  1200, 1200),

    # ic_notification_icon — 通知栏图标（较小）
    ("drawable-mdpi",    "ic_notification_icon.png",  24,  24),
    ("drawable-hdpi",    "ic_notification_icon.png",  36,  36),
    ("drawable-xhdpi",   "ic_notification_icon.png",  48,  48),
    ("drawable-xxhdpi",  "ic_notification_icon.png",  72,  72),
    ("drawable-xxxhdpi", "ic_notification_icon.png",  96,  96),
]


def generate(src_path: Path, specs: list, res_dir: Path):
    print(f"📂 源文件: {src_path}")
    print(f"📐 原始尺寸: {Image.open(src_path).size}")
    print()

    src = Image.open(src_path).convert("RGBA")

    generated = 0
    for (folder, filename, w, h) in specs:
        out_dir = res_dir / folder
        out_dir.mkdir(parents=True, exist_ok=True)
        out_path = out_dir / filename

        resized = src.resize((w, h), Image.LANCZOS)

        # 通知图标需要白色单色处理（Android 规范：通知图标只看 alpha 通道）
        # 这里保留彩色，符合现代 Android 通知图标的实际用法
        resized.save(out_path, "PNG", optimize=True)
        print(f"  ✅ {folder}/{filename}  {w}×{h}")
        generated += 1

    print()
    print(f"🎉 完成！共生成 {generated} 个图标文件")


def main():
    if not SOURCE_ICON.exists():
        print(f"❌ 找不到源图标: {SOURCE_ICON}")
        print(f"   请将你的 logo（建议 512×512）放到 apk/store_icon.png")
        sys.exit(1)

    generate(SOURCE_ICON, ICON_SPECS, RES_DIR)


if __name__ == "__main__":
    main()
