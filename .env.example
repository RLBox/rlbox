# ──────────────────────────────────────────────────────────────
# 本地开发端口分配（多个 App 同时跑不冲突）
#   Goomart   → 11601
#   IdleSwap  → 11602
#   Kangoo    → 11603
#   planet    → 11604
#   duvy      → 11605
#   <next>    → 11606  (新派生项目：取下一个可用号)
# ──────────────────────────────────────────────────────────────
#
# 用法：
#   1. 复制此文件为 .env（.env 已在 .gitignore 中，不会被提交）
#         cp .env.example .env
#   2. 按本机派生项目分配表，填入本项目对应的端口
#   3. `bin/dev` 会自动加载 .env（详见 bin/dev 第 43-53 行）
#
# 优先级：ENV['APP_PORT'] > .env > config/application.yml > EnvChecker 兜底（3000/3001）

APP_PORT=11600
PORT=11600
